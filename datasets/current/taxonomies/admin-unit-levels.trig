<https://linkeddata.lt/taxonomies/admin-unit-levels/> {
    <https://linkeddata.lt/taxonomies/admin-unit-levels/#this>
            a                skos:ConceptScheme;
            dct:description  "Extends the EU ATU-type authority table (atu-type:LTU_*) with levels it does not cover."@en;
            skos:prefLabel   "Supplementary territorial unit levels"@en , "Papildomi teritorinių vienetų lygmenys"@lt .
    
    <https://linkeddata.lt/taxonomies/admin-unit-levels/>
