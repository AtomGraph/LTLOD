PREFIX cv:       <http://data.europa.eu/m8g/>
PREFIX dct:      <http://purl.org/dc/terms/>
PREFIX foaf:     <http://xmlns.com/foaf/0.1/>
PREFIX skos:     <http://www.w3.org/2004/02/skos/core#>
PREFIX schema:   <https://schema.org/>
PREFIX xsd:      <http://www.w3.org/2001/XMLSchema#>
PREFIX atu-type: <http://publications.europa.eu/resource/authority/atu-type/>

PREFIX dh:   <https://www.w3.org/ns/ldt/document-hierarchy#>
PREFIX sioc: <http://rdfs.org/sioc/ns#>

CONSTRUCT
{
    GRAPH ?graph
    {
        ?graph a dh:Item ;
            sioc:has_container ?container ;
            dct:title ?title ;
            foaf:primaryTopic ?unit .

        ?unit a cv:AdminUnit ;
            cv:level atu-type:LTU_SEN ;
            skos:prefLabel ?title ;
            skos:notation ?code ;
            dct:identifier ?code ;
            dct:isPartOf ?municipality ;
            schema:validFrom ?validFrom ;
            schema:validThrough ?validThrough .
    }
}
WHERE
{
    ?row <#sen_kodas> ?codeRaw ;
        <#pavadinimas> ?name ;
        <#savivaldybe.sav_kodas> ?munCodeRaw .
    OPTIONAL { ?row <#sen_nuo> ?nuo }
    OPTIONAL { ?row <#sen_iki> ?iki }

    BIND(str(?codeRaw) AS ?code)
    BIND(str(?munCodeRaw) AS ?munCode)
    BIND(STRLANG(concat(?name, " seniūnija"), "lt") AS ?title)
    BIND(uri(concat(str($base), "admin-units/")) AS ?container)
    BIND(uri(concat(str(?container), encode_for_uri(?code), "/")) AS ?graph)
    BIND(uri(concat(str(?graph), "#this")) AS ?unit)
    BIND(uri(concat(str(?container), encode_for_uri(?munCode), "/#this")) AS ?municipality)
    BIND(IF(BOUND(?nuo) && ?nuo != "", STRDT(str(?nuo), xsd:date), ?undef) AS ?validFrom)
    BIND(IF(BOUND(?iki) && ?iki != "", STRDT(str(?iki), xsd:date), ?undef) AS ?validThrough)
}
