@prefix def: <https://w3id.org/atomgraph/linkeddatahub/default#> .
@prefix ldh: <https://w3id.org/atomgraph/linkeddatahub#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dct: <http://purl.org/dc/terms/> .

<> a def:Root ;
    dct:title "Lietuvos susietieji atvirieji duomenys"@lt ;
    dct:description "Lietuvos atvirieji duomenys, sujungti į vientisą RDF žinių grafą: administraciniai vienetai, Seimo nariai, juridiniai asmenys, klasifikatoriai."@lt ;
    rdf:_1 <#select-children> .

<#select-children> a ldh:Object ;
    rdf:value ldh:ChildrenView .
